{
  "name": "manuscript-tracker",
  "private": true,
  "scripts": {
    "build": "cd frontend && npm run build",
    "deploy": "npm run build && wrangler deploy",
    "dev": "wrangler dev",
    "db:migrate:v1": "wrangler d1 execute manuscript-tracker-db --remote --file=migrations/0001_init.sql",
    "db:migrate:v2": "wrangler d1 execute manuscript-tracker-db --remote --file=migrations/0002_multi_tenant.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "wrangler": "^4.14.0",
    "typescript": "^5.8.0"
  }
}
