{
  "name": "manuscript-tracker",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:api": "wrangler dev workers/api/src/index.ts --port 8787",
    "build:frontend": "cd frontend && npm run build",
    "deploy": "npm run build:frontend && wrangler deploy",
    "db:migrate": "wrangler d1 execute manuscript-tracker-db --local --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "wrangler": "^4.14.0",
    "typescript": "^5.8.0"
  }
}
